#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

export UV_CACHE_DIR="${UV_CACHE_DIR:-.uv-cache}"
export PYTHONPATH="${PYTHONPATH:-src}"

PYTHON_BIN="${PYTHON_BIN:-python}"
if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  PYTHON_BIN="python3"
fi

if [[ -n "${TAXICAB_E2E_WORK_DIR:-}" ]]; then
  WORK_DIR="$TAXICAB_E2E_WORK_DIR"
else
  WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/taxicab-e2e.XXXXXX")"
fi

FIXTURE_DIR="$WORK_DIR/fixtures"
CACHE_DIR="$WORK_DIR/cache"
ARTIFACT_DIR="${TAXICAB_E2E_ARTIFACT_DIR:-$WORK_DIR/artifacts}"

run_taxicab() {
  uv run \
    --with numpy \
    --with scipy \
    --with tqdm \
    --with PySCIPOpt \
    --no-project \
    python -m taxicab.cli "$@"
}

construct_short() {
  local output="$1"
  local seed="$2"
  shift 2

  run_taxicab construct \
    --data-dir "$CACHE_DIR" \
    --sample-size 4 \
    --error-margin 0.20 \
    --target-tax-alpha 0.001 \
    --tax-metric simulated \
    --rebalance-frequency monthly \
    --harvest-frequency monthly \
    --min-observations 50 \
    --selection-iterations 8 \
    --weight-iterations 40 \
    --no-progress \
    --seed "$seed" \
    --output "$output" \
    "$@"
}

require_file() {
  local path="$1"
  if [[ ! -f "$path" ]]; then
    echo "Missing required e2e file: $path" >&2
    echo "Run ./scripts/e2e_ci setup first, or set TAXICAB_E2E_WORK_DIR consistently across steps." >&2
    exit 1
  fi
}

require_setup() {
  require_file "$FIXTURE_DIR/holdings.csv"
  require_file "$FIXTURE_DIR/index_prices.csv"
  require_file "$FIXTURE_DIR/prices.csv"
  require_file "$FIXTURE_DIR/current_positions.csv"
  require_file "$CACHE_DIR/metadata.json"
  require_file "$CACHE_DIR/holdings.csv"
  require_file "$CACHE_DIR/prices.csv"
}

generate_fixtures() {
  mkdir -p "$FIXTURE_DIR" "$CACHE_DIR" "$ARTIFACT_DIR"
  "$PYTHON_BIN" - "$FIXTURE_DIR" <<'PY'
from __future__ import annotations

import csv
import math
import sys
from datetime import date, timedelta
from pathlib import Path

fixture_dir = Path(sys.argv[1])
fixture_dir.mkdir(parents=True, exist_ok=True)

holdings_path = fixture_dir / "holdings.csv"
index_prices_path = fixture_dir / "index_prices.csv"
prices_path = fixture_dir / "prices.csv"
current_positions_path = fixture_dir / "current_positions.csv"

tickers = ["AAA", "BBB", "CCC", "DDD", "EEE", "FFF", "GGG", "HHH"]
sectors = ["Tech", "Tech", "Health", "Health", "Finance", "Finance", "Industrial", "Industrial"]
weights = [0.18, 0.14, 0.16, 0.12, 0.13, 0.10, 0.09, 0.08]

with holdings_path.open("w", newline="", encoding="utf-8") as handle:
    writer = csv.DictWriter(handle, fieldnames=["ticker", "weight", "sector", "industry"])
    writer.writeheader()
    for ticker, weight, sector in zip(tickers, weights, sectors):
        writer.writerow(
            {
                "ticker": ticker,
                "weight": weight,
                "sector": sector,
                "industry": f"{sector} Tools",
            }
        )

start = date(2021, 1, 1)
days = 90
benchmark_price = 100.0
ticker_prices = {ticker: 40.0 + idx * 7.0 for idx, ticker in enumerate(tickers)}
return_multipliers = [0.95, 1.02, 1.08, 0.88, 1.15, 0.75, 1.25, 0.68]
return_offsets = [0.0000, 0.0004, -0.0003, 0.0008, -0.0005, 0.0010, -0.0008, 0.0012]

index_rows = []
price_rows = []
for day_index in range(days):
    day = start + timedelta(days=day_index)
    benchmark_return = (
        0.0004
        + 0.008 * math.sin(day_index / 5.0)
        - (0.018 if day_index in {20, 21, 22, 55} else 0.0)
        + (0.012 if day_index in {38, 70} else 0.0)
    )
    benchmark_price *= 1.0 + benchmark_return
    index_rows.append({"date": day.isoformat(), "adj_close": f"{benchmark_price:.8f}"})

    for ticker_index, ticker in enumerate(tickers):
        ticker_return = (
            benchmark_return * return_multipliers[ticker_index]
            + return_offsets[ticker_index]
            + 0.002 * math.sin((day_index + ticker_index) / (4.0 + ticker_index % 3))
        )
        ticker_prices[ticker] *= 1.0 + ticker_return
        price_rows.append(
            {
                "date": day.isoformat(),
                "ticker": ticker,
                "adj_close": f"{ticker_prices[ticker]:.8f}",
            }
        )

with index_prices_path.open("w", newline="", encoding="utf-8") as handle:
    writer = csv.DictWriter(handle, fieldnames=["date", "adj_close"])
    writer.writeheader()
    writer.writerows(index_rows)

with prices_path.open("w", newline="", encoding="utf-8") as handle:
    writer = csv.DictWriter(handle, fieldnames=["date", "ticker", "adj_close"])
    writer.writeheader()
    writer.writerows(price_rows)

with current_positions_path.open("w", newline="", encoding="utf-8") as handle:
    writer = csv.DictWriter(handle, fieldnames=["ticker", "shares", "price", "cost_basis"])
    writer.writeheader()
    for ticker_index, ticker in enumerate(tickers[:5]):
        shares = 10 + ticker_index
        price = ticker_prices[ticker]
        cost_basis_multiplier = 1.08 if ticker_index == 0 else 0.92
        writer.writerow(
            {
                "ticker": ticker,
                "shares": shares,
                "price": f"{price:.4f}",
                "cost_basis": f"{shares * price * cost_basis_multiplier:.2f}",
            }
        )
    writer.writerow({"ticker": "ZZZ", "shares": "3", "price": "50.00", "cost_basis": "120.00"})
PY
}

download_cache() {
  run_taxicab download \
    --index IDX \
    --holdings-csv "$FIXTURE_DIR/holdings.csv" \
    --index-prices-csv "$FIXTURE_DIR/index_prices.csv" \
    --prices-csv "$FIXTURE_DIR/prices.csv" \
    --data-dir "$CACHE_DIR" \
    --start 2021-01-01 \
    --end 2021-03-31 \
    --sector-source none
}

setup_e2e() {
  generate_fixtures
  download_cache
  echo "Taxicab e2e fixture written to $WORK_DIR"
}

validate_optimization_rebalance() {
  "$PYTHON_BIN" - "$ARTIFACT_DIR" <<'PY'
from __future__ import annotations

import csv
import json
import sys
from pathlib import Path

artifact_dir = Path(sys.argv[1])
portfolio_path = artifact_dir / "optimized.json"
if not portfolio_path.is_file() or portfolio_path.stat().st_size == 0:
    raise SystemExit(f"missing portfolio artifact: {portfolio_path}")

portfolio = json.loads(portfolio_path.read_text(encoding="utf-8"))
positions = portfolio.get("positions")
if not isinstance(positions, list) or len(positions) != 4:
    raise SystemExit("optimized.json should contain four positions")

tracking_artifact = portfolio.get("tracking_model_artifact", {})
if not isinstance(tracking_artifact, dict):
    raise SystemExit("optimized.json is missing tracking_model_artifact")
tracking_path = artifact_dir / str(tracking_artifact.get("path", ""))
if not tracking_path.is_file() or tracking_path.stat().st_size == 0:
    raise SystemExit(f"missing tracking model artifact: {tracking_path}")

orders_path = artifact_dir / "orders.csv"
if not orders_path.is_file() or orders_path.stat().st_size == 0:
    raise SystemExit("missing orders.csv")
with orders_path.open(newline="", encoding="utf-8") as handle:
    orders = list(csv.DictReader(handle))
if not orders:
    raise SystemExit("orders.csv should contain actionable rows")
PY
}

optimization_rebalance() {
  mkdir -p "$ARTIFACT_DIR"
  require_setup

  construct_short "$ARTIFACT_DIR/optimized.json" 11
  run_taxicab rebalance \
    --state "$ARTIFACT_DIR/optimized.json" \
    --current-csv "$FIXTURE_DIR/current_positions.csv" \
    --output "$ARTIFACT_DIR/orders.csv" \
    --drift-threshold-pct 0.001 \
    --harvest-loss-threshold-pct 0.03

  validate_optimization_rebalance
  echo "Taxicab optimization/rebalance artifacts written to $ARTIFACT_DIR"
}

validate_comparison() {
  "$PYTHON_BIN" - "$ARTIFACT_DIR" <<'PY'
from __future__ import annotations

import json
import sys
from pathlib import Path

artifact_dir = Path(sys.argv[1])
portfolio_names = ["baseline", "weighted", "greedy"]

for name in portfolio_names:
    portfolio_path = artifact_dir / f"{name}.json"
    if not portfolio_path.is_file() or portfolio_path.stat().st_size == 0:
        raise SystemExit(f"missing portfolio artifact: {portfolio_path}")
    portfolio = json.loads(portfolio_path.read_text(encoding="utf-8"))
    positions = portfolio.get("positions")
    if not isinstance(positions, list) or len(positions) != 4:
        raise SystemExit(f"{portfolio_path} should contain four positions")
    tracking_artifact = portfolio.get("tracking_model_artifact", {})
    if not isinstance(tracking_artifact, dict):
        raise SystemExit(f"{portfolio_path} is missing tracking_model_artifact")
    tracking_path = artifact_dir / str(tracking_artifact.get("path", ""))
    if not tracking_path.is_file() or tracking_path.stat().st_size == 0:
        raise SystemExit(f"missing tracking model artifact: {tracking_path}")

comparison_path = artifact_dir / "comparison.json"
comparison = json.loads(comparison_path.read_text(encoding="utf-8"))
if sorted(comparison.get("portfolios", {})) != ["baseline", "greedy", "weighted"]:
    raise SystemExit("comparison.json should contain baseline, greedy, and weighted portfolios")
if len(comparison.get("pairwise", [])) != 3:
    raise SystemExit("comparison.json should contain three pairwise comparisons")

html_path = artifact_dir / "comparison.html"
html = html_path.read_text(encoding="utf-8")
if "Taxicab Comparison Report" not in html:
    raise SystemExit("comparison.html should contain the comparison report")
PY
}

comparison() {
  mkdir -p "$ARTIFACT_DIR"
  require_setup

  construct_short "$ARTIFACT_DIR/baseline.json" 21
  construct_short \
    "$ARTIFACT_DIR/weighted.json" \
    22 \
    --selection-method random-weighted \
    --weight-method index-normalized \
    --allow-constraint-violations
  construct_short \
    "$ARTIFACT_DIR/greedy.json" \
    23 \
    --selection-method greedy \
    --weight-method index-normalized \
    --allow-constraint-violations

  run_taxicab compare \
    --data-dir "$CACHE_DIR" \
    --portfolio "baseline=$ARTIFACT_DIR/baseline.json" \
    --portfolio "weighted=$ARTIFACT_DIR/weighted.json" \
    --portfolio "greedy=$ARTIFACT_DIR/greedy.json" \
    --output "$ARTIFACT_DIR/comparison.json" \
    --html-output "$ARTIFACT_DIR/comparison.html"

  validate_comparison
  echo "Taxicab comparison artifacts written to $ARTIFACT_DIR"
}

run_all() {
  setup_e2e
  optimization_rebalance
  comparison
  echo "Taxicab e2e artifacts written to $ARTIFACT_DIR"
}

usage() {
  cat <<'EOF'
Usage: scripts/e2e_ci [all|setup|optimization-rebalance|comparison]

Commands:
  all                      Generate fixtures and run every e2e scenario. Default.
  setup                    Generate deterministic fixture data and offline cache.
  optimization-rebalance   Run one short optimization and rebalance validation.
  comparison               Run three short optimizations and comparison validation.
EOF
}

command="${1:-all}"
case "$command" in
  all)
    run_all
    ;;
  setup)
    setup_e2e
    ;;
  optimization-rebalance)
    optimization_rebalance
    ;;
  comparison)
    comparison
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
